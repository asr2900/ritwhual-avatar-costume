# WalletConnect — daftar di https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id

# Jaringan: base | baseSepolia | polygon | polygonAmoy
NEXT_PUBLIC_CHAIN=baseSepolia

# Kontrak mint NFT (opsional — tanpa ini, mint simulasi setelah connect wallet)
NEXT_PUBLIC_MINT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Biaya mint dalam ETH (hanya tampilan + value tx jika kontrak payable)
NEXT_PUBLIC_MINT_PRICE_ETH=0.001

# Profil X/Twitter team (tanpa @)
NEXT_PUBLIC_TWITTER_HANDLE=ritwhual

# Teks share ke X setelah download
NEXT_PUBLIC_SHARE_TEXT=I just crafted my 1:1 RITWHUAL AVATAR COSTUME — join the ritual.
